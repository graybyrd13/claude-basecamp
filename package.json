    "test": "node --test \"test/*.test.js\""
  },
  "keywords": [
    "claude",
    "claude-code",
    "dashboard",
    "sessions",
    "agents",
    "token-usage",
    "mcp",
    "anthropic"
  ],
  "files": [
    "bin/",
    "src/",
    "public/",
    "README.md",
    "LICENSE"
  ]
}
